{
	"mcpServers": {
		"memory-bank": {
			"command": "npx",
			"args": ["-y", "@aakarsh-sasi/memory-bank-mcp@latest"],
			"env": {
				"MEMORY_ROOT": "./.jabber/memory"
			},
			"disabled": false,
			"alwaysAllow": []
		},
		"fetch": {
			"command": "uvx",
			"args": ["mcp-server-fetch"],
			"disabled": false,
			"alwaysAllow": ["fetch"]
		},
		"playwright": {
			"command": "npx",
			"args": ["-y", "@playwright/mcp@latest"],
			"disabled": false,
			"alwaysAllow": [
				"browser_click",
				"browser_fill",
				"browser_select",
				"browser_hover",
				"browser_evaluate",
				"browser_get_html",
				"browser_wait_for_selector",
				"browser_navigate",
				"browser_screenshot",
				"browser_close",
				"browser_set_viewport",
				"browser_file_upload",
				"browser_drag"
			]
		},
		"redis": {
			"command": "npx",
			"args": ["-y", "@modelcontextprotocol/server-redis"],
			"env": {
				"REDIS_URL": "redis://127.0.0.1:6379"
			},
			"disabled": false,
			"alwaysAllow": []
		},
		"docker": {
			"command": "docker",
			"args": ["mcp", "gateway", "run"],
			"disabled": false,
			"alwaysAllow": ["mcp-find", "mcp-exec"],
			"disabledTools": ["code-mode", "mcp-config-set"]
		},
		"md-todo-mcp": {
			"command": "node",
			"args": ["/Users/mikita_dusmikeev/Documents/Work/jabberwock/Jabberwock/md-todo-mcp/build/index.js"],
			"alwaysAllow": ["manage_todo_plan"],
			"isGloballyVisible": false,
			"env": {
				"HTTP_PORT": "3002"
			}
		}
	}
}
